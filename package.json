{
  "name": "fabtrack",
  "version": "1.0.0",
  "private": true,
  "description": "FabTrack — Fabrication shop operations management",
  "scripts": {
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npm run build",
    "start": "cd server && npm start",
    "db:init": "cd server && node db/init.js",
    "db:seed": "cd server && node db/seed.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}

# ─── FabTrack Server Configuration ───
# Copy this file to .env and fill in your values

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/fabtrack

# JWT Secret — generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_to_a_random_64_char_string

# Server
PORT=3001
NODE_ENV=development

# File uploads — local storage path (for production, switch to S3/Cloudinary)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
